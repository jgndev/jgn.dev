package lockups

import "github.com/jgndev/jgn.dev/internal/views/icons"

templ Tools() {
	<div class="">
		<h2 class="uppercase text-xl">Tools of the Trade:</h2>
		<div class="brand-block">
			@icons.Git()
			@icons.GitHub()
			@icons.Docker()
			@icons.Kubernetes()
			@icons.Terraform()
			@icons.Packer()
			@icons.Ansible()
			@icons.Aws()
			@icons.Neovim()
		</div>
	</div>
}
